				<textElement>
					<font isBold="true"/>
				</textElement>
				<textFieldExpression><![CDATA[$F{estado}.toString().equals("INFORMADA")
|| $F{estado}.toString().equals("ANULADA")
? "INFORME FINAL"
: "INFORME PRELIMINAR"]]></textFieldExpression>
			</textField>
		</band>
	</title>
