new java.text.SimpleDateFormat("dd/MM/yyyy").format(
    new java.text.SimpleDateFormat("yyyy-MM-dd").parse($F{fecha_nacimiento}.toString())
)]]></textFieldExpression>
			</textField>
			<textField>
